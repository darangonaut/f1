<!DOCTYPE html>
<html lang="sk">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width,initial-scale=1">
	<meta name="theme-color" content="#f5e6d3">
	<link rel="icon" type="image/svg+xml" href="/favicon.svg">
	<link rel="apple-touch-icon" href="/favicon.svg">
	<title>{ifset title}{include title|stripHtml} · {/ifset}F1 · markuska.cz</title>

	{asset? 'main.js'}
</head>
<body class="min-h-screen">

<div class="max-w-[820px] mx-auto px-4 py-8 sm:py-10">

	<header class="text-center mb-10">
		<div class="text-xs mb-2 flex justify-between items-baseline">
			<a href="{plink Home:default}" class="no-underline hover:text-accent">f1.markuska.cz</a>
			<span class="text-ink-soft">openf1.org</span>
		</div>
		<h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Formula 1</h1>
	</header>

	<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">{$flash->message}</div>

	{include content}

	<footer class="mt-16 pt-4 border-t border-ink/20 text-xs text-ink-soft text-center space-y-1">
		<div>
			<a href="https://openf1.org/" target="_blank">openf1.org</a>
			·
			<a href="https://markuska.cz" target="_blank">markuska.cz</a>
			·
			<a href="https://github.com/darangonaut/f1" target="_blank">source</a>
		</div>
		<div n:if="isset($lastSyncAt) && $lastSyncAt !== null">
			Data loaded: <time datetime="{$lastSyncAt->format('c')}">{$lastSyncAt->format('j. n. Y · H:i')}</time>
		</div>
	</footer>

</div>
</body>
</html>
